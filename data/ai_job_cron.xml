<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_bpi_ai_job_processor" model="ir.cron">
        <field name="name">Producto Intelligence: procesar jobs IA</field>
        <field name="model_id" ref="model_bpi_ai_job"/>
        <field name="state">code</field>
        <field name="code">model._cron_process_pending_jobs(limit=1)</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
