# Copy to .env for local/deploy use. Never commit real secrets.

# Optional deploy metadata used by local runbooks/scripts outside this addon.
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PASSWORD=
DEPLOY_PORT=22
DEPLOY_DOMAIN=
DEPLOY_DROPLET_ID=
DEPLOY_DB=
DEPLOY_ADDON_PATH=/opt/odoo/custom/addons/bader_product_intelligence
DEPLOY_ODOO_BIN=/opt/odoo/odoo-bin
DEPLOY_ODOO_CONF=/etc/odoo/odoo.conf

# Optional GitHub credentials for local automation only.
GITHUB_TOKEN=
GIT_TOKEN=
GITHUB_USER=

# Producto Intelligence external services.
BPI_OPENAI_API_KEY=
OPENAI_API_KEY=
BPI_OPENAI_TEXT_MODEL=gpt-5.5
BPI_OPENAI_IMAGE_MODEL=gpt-image-2
BPI_OPENAI_IMAGE_EDIT_MODEL=gpt-image-1.5
BPI_OPENAI_REASONING_EFFORT=low
BPI_OPENAI_TEXT_VERBOSITY=medium
BPI_FIRECRAWL_API_KEY=
FIRECRAWL_API_KEY=
BPI_FIRECRAWL_BASE_URL=https://api.firecrawl.dev
